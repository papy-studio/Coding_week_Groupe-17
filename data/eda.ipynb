import { useState, useEffect } from "react";
import { BoxPlot } from "@visx/stats";
import * as d3 from "d3";

const data = {
  Age:     [14, 19.7, 22.8, 26.1, 31.2, 61],
  Height:  [1.45, 1.60, 1.68, 1.71, 1.78, 1.98],
  Weight:  [39, 57.2, 72.1, 85.9, 106.3, 173],
  FCVC:    [1, 2, 2, 2.4, 3, 3],
  NCP:     [1, 1, 3, 3, 3, 4],
  CH2O:    [1, 1.6, 2, 2.2, 2.8, 3],
  FAF:     [0, 0, 0.9, 1.3, 2.3, 3],
  TUE:     [0, 0.3, 0.6, 0.9, 1.4, 2],
};

function computeBoxStats(values) {
  const sorted = [...values].sort(d3.ascending);
  const q1 = d3.quantile(sorted, 0.25);
  const median = d3.quantile(sorted, 0.5);
  const q3 = d3.quantile(sorted, 0.75);
  const iqr = q3 - q1;
  const min = Math.max(sorted[0], q1 - 1.5 * iqr);
  const max = Math.min(sorted[sorted.length - 1], q3 + 1.5 * iqr);
  const outliers = sorted.filter(v => v < min || v > max);
  return { min, q1, median, q3, max, outliers };
}

function SingleBoxPlot({ col, values, width = 100, height = 200 }) {
  const stats = computeBoxStats(values);
  const allVals = [stats.min, stats.max, ...stats.outliers];
  const yMin = Math.min(...allVals) - (stats.max - stats.min) * 0.1;
  const yMax = Math.max(...allVals) + (stats.max - stats.min) * 0.1;
  const pad = { top: 18, bottom: 18, left: 20, right: 20 };
  const innerH = height - pad.top - pad.bottom;
  const innerW = width - pad.left - pad.right;
  const yScale = v => pad.top + innerH - ((v - yMin) / (yMax - yMin)) * innerH;
  const cx = pad.left + innerW / 2;
  const bw = innerW * 0.5;

  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center" }}>
      <svg width={width} height={height} style={{ overflow: "visible" }}>
        {/* Whisker lines */}
        <line x1={cx} y1={yScale(stats.min)} x2={cx} y2={yScale(stats.q1)} stroke="#555" strokeWidth={1.5} />
        <line x1={cx} y1={yScale(stats.q3)} x2={cx} y2={yScale(stats.max)} stroke="#555" strokeWidth={1.5} />
        {/* Whisker caps */}
        <line x1={cx - bw/3} y1={yScale(stats.min)} x2={cx + bw/3} y2={yScale(stats.min)} stroke="#555" strokeWidth={1.5} />
        <line x1={cx - bw/3} y1={yScale(stats.max)} x2={cx + bw/3} y2={yScale(stats.max)} stroke="#555" strokeWidth={1.5} />
        {/* Box */}
        <rect
          x={cx - bw / 2}
          y={yScale(stats.q3)}
          width={bw}
          height={Math.abs(yScale(stats.q1) - yScale(stats.q3))}
          fill="white"
          stroke="#555"
          strokeWidth={1.5}
        />
        {/* Median */}
        <line
          x1={cx - bw / 2} y1={yScale(stats.median)}
          x2={cx + bw / 2} y2={yScale(stats.median)}
          stroke="#ff7f0e" strokeWidth={2}
        />
        {/* Outliers */}
        {stats.outliers.map((v, i) => (
          <circle key={i} cx={cx} cy={yScale(v)} r={3} fill="none" stroke="#1f77b4" strokeWidth={1} />
        ))}
        {/* Y axis ticks */}
        {[yMin, (yMin+yMax)/2, yMax].map((v, i) => (
          <g key={i}>
            <line x1={pad.left - 4} y1={yScale(v)} x2={pad.left} y2={yScale(v)} stroke="#aaa" strokeWidth={1} />
            <text x={pad.left - 6} y={yScale(v) + 4} textAnchor="end" fontSize={9} fill="#666">
              {v.toFixed(v < 10 ? 2 : 0)}
            </text>
          </g>
        ))}
        {/* Y axis line */}
        <line x1={pad.left} y1={pad.top} x2={pad.left} y2={pad.top + innerH} stroke="#ccc" strokeWidth={1} />
      </svg>
      <div style={{ fontSize: 12, color: "#333", marginTop: 4, fontFamily: "monospace" }}>{col}</div>
    </div>
  );
}

export default function App() {
  const cols = Object.keys(data);

  return (
    <div style={{
      fontFamily: "'DejaVu Sans', monospace, sans-serif",
      background: "#fff",
      minHeight: "100vh",
      padding: "24px 16px",
    }}>
      {/* Combined boxplot */}
      <div style={{
        border: "1px solid #ddd",
        borderRadius: 4,
        padding: "16px 20px 8px",
        marginBottom: 24,
        background: "#fafafa",
      }}>
        <div style={{ fontWeight: "bold", fontSize: 14, color: "#333", marginBottom: 12, textAlign: "center" }}>
          Détection des outliers
        </div>
        <div style={{ display: "flex", alignItems: "flex-end", gap: 0, overflowX: "auto" }}>
          {cols.map(col => (
            <SingleBoxPlot key={col} col={col} values={data[col]} width={110} height={220} />
          ))}
        </div>
      </div>

      {/* Individual boxplots grid */}
      <div style={{
        border: "1px solid #ddd",
        borderRadius: 4,
        padding: "16px 20px 8px",
        background: "#fafafa",
      }}>
        <div style={{ fontWeight: "bold", fontSize: 14, color: "#333", marginBottom: 16, textAlign: "center" }}>
          Outliers par variable
        </div>
        <div style={{
          display: "grid",
          gridTemplateColumns: "repeat(4, 1fr)",
          gap: "8px 4px",
        }}>
          {cols.map(col => (
            <div key={col} style={{
              border: "1px solid #eee",
              borderRadius: 3,
              padding: "10px 4px 4px",
              background: "#fff",
              display: "flex",
              flexDirection: "column",
              alignItems: "center",
            }}>
              <div style={{ fontSize: 11, fontWeight: "bold", color: "#333", marginBottom: 4 }}>{col}</div>
              <SingleBoxPlot col="" values={data[col]} width={100} height={180} />
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
